@model Global_Logistics_Management_System.Models.ViewModels.ServiceRequestEditViewModel
@{
    ViewData["Title"] = $"Update Status – Request #{Model.Id}";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Details" asp-route-id="@Model.Id" class="text-muted me-3"><i class="fas fa-arrow-left"></i></a>
    <h2 class="fw-bold mb-0"><i class="fas fa-edit me-2 text-primary"></i>Update Status</h2>
</div>

<div class="row">
    <div class="col-lg-6 mx-auto">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0">Request #@Model.Id – @Model.ContractInfo</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="Id" />

                    <!-- Read-only info (not submitted) -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Current Description</label>
                        <div class="form-control-plaintext bg-light p-3 rounded">@Model.CurrentDescription</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Current Cost (ZAR)</label>
                        <div class="form-control-plaintext bg-light p-3 rounded">@Model.CurrentCost.ToString("C")</div>
                    </div>

                    <!-- Editable Status -->
                    <div class="mb-4">
                        <label asp-for="Status" class="form-label fw-semibold"></label>
                        <select asp-for="Status" class="form-select" asp-items="ViewBag.StatusList"></select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <!-- Optional change note -->
                    <div class="mb-4">
                        <label asp-for="ChangeNote" class="form-label fw-semibold"></label>
                        <textarea asp-for="ChangeNote" class="form-control" rows="2" placeholder="Add a note about this change..."></textarea>
                        <span asp-validation-for="ChangeNote" class="text-danger small"></span>
                    </div>

                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fas fa-save me-1"></i> Update Status
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}