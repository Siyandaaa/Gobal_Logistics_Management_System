@using Global_Logistics_Management_System.Models.Entities
@model List<Client>

@{
    ViewData["Title"] = "Clients";
    var searchString = ViewBag.SearchString as string;
    var regionFilter = ViewBag.RegionFilter as string;
    var regions = ViewBag.Regions as List<string>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fas fa-users me-2 text-primary"></i>Client Management</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus-circle me-1"></i> New Client
    </a>
</div>

<!-- Filter Card -->
<div class="filter-card shadow-sm">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label fw-semibold"><i class="fas fa-search me-1"></i>Search</label>
            <input type="text" name="searchString" class="form-control" placeholder="Name or contact details..." value="@searchString" />
        </div>
        <div class="col-md-4">
            <label class="form-label fw-semibold"><i class="fas fa-globe me-1"></i>Region</label>
            <select name="region" class="form-select">
                <option value="">All Regions</option>
                @if (regions != null)
                {
                    @foreach (var reg in regions)
                    {
                        <!option value="@reg" selected="@(regionFilter == reg ? "selected" : null)">@reg</!option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-filter me-1"></i> Apply
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                <i class="fas fa-undo-alt me-1"></i> Reset
            </a>
        </div>
    </form>
</div>

<!-- Clients Grid (Card-based for better visual) -->
<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="card shadow-sm border-0 text-center py-5">
                <div class="card-body">
                    <i class="fas fa-user-slash fa-4x mb-3 text-muted opacity-50"></i>
                    <h4>No clients found</h4>
                    <p class="text-muted">Create a new client to get started.</p>
                    <a asp-action="Create" class="btn btn-primary mt-2">
                        <i class="fas fa-plus me-1"></i> Add Client
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        @foreach (var client in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100 client-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="fas fa-building fa-2x text-primary"></i>
                            </div>
                            <div>
                                <h5 class="card-title mb-0 fw-bold">@client.Name</h5>
                                <span class="badge bg-light text-dark">@client.Region</span>
                            </div>
                        </div>
                        <p class="card-text">
                            <i class="fas fa-address-card me-2 text-muted"></i>@client.ContactDetails
                        </p>
                    </div>
                    <div class="card-footer bg-white border-0 pt-0 pb-3">
                        <div class="d-flex justify-content-between">
                            <a asp-action="Details" asp-route-id="@client.ClientId" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye me-1"></i> View
                            </a>
                            <a asp-action="Edit" asp-route-id="@client.ClientId" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-edit me-1"></i> Edit
                            </a>
                            <a asp-controller="Contracts" asp-action="Create" asp-route-clientId="@client.ClientId" class="btn btn-sm btn-outline-success">
                                <i class="fas fa-file-contract me-1"></i> New Contract
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Summary Stats -->
<div class="row mt-4 g-3">
    <div class="col-md-4">
        <div class="card stat-card bg-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted text-uppercase small">Total Clients</h6>
                        <h3 class="mb-0">@Model.Count</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded">
                        <i class="fas fa-users fa-2x text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card bg-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted text-uppercase small">Regions Served</h6>
                        <h3 class="mb-0">@(regions?.Count ?? 0)</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded">
                        <i class="fas fa-map-marked-alt fa-2x text-success"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card bg-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted text-uppercase small">Active Contracts</h6>
                        <h3 class="mb-0">@ViewBag.ActiveContracts</h3>
                    </div>
                    <div class="bg-info bg-opacity-10 p-3 rounded">
                        <i class="fas fa-file-signature fa-2x text-info"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .client-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .client-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>