@using Global_Logistics_Management_System.Models.Entities
@model Global_Logistics_Management_System.Models.Entities.Client
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="text-muted me-3"><i class="fas fa-arrow-left"></i></a>
    <h2 class="fw-bold mb-0">@Model.Name</h2>
    <span class="ms-3"><span class="badge bg-light text-dark">@Model.Region</span></span>
    <div class="ms-auto">
        <a asp-action="Edit" asp-route-id="@Model.ClientId" class="btn btn-outline-primary me-2">
            <i class="fas fa-edit me-1"></i> Edit
        </a>
        <a asp-controller="Contracts" asp-action="Create" asp-route-clientId="@Model.ClientId" class="btn btn-primary">
            <i class="fas fa-file-contract me-1"></i> New Contract
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-info-circle me-2 text-primary"></i>Client Information</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">ID</dt>
                    <dd class="col-sm-9">@Model.ClientId</dd>

                    <dt class="col-sm-3 text-muted">Contact</dt>
                    <dd class="col-sm-9">@Model.ContactDetails</dd>

                    <dt class="col-sm-3 text-muted">Region</dt>
                    <dd class="col-sm-9">@Model.Region</dd>

                    <dt class="col-sm-3 text-muted">Contracts</dt>
                    <dd class="col-sm-9">@(Model.Contracts?.Count ?? 0) active/completed</dd>
                </dl>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="row g-3 mt-2">
            <div class="col-md-6">
                <div class="card stat-card bg-white">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 p-2 rounded me-2">
                                <i class="fas fa-file-contract text-primary"></i>
                            </div>
                            <div>
                                <small class="text-muted">Total Contracts</small>
                                <h5 class="mb-0">@(Model.Contracts?.Count ?? 0)</h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card stat-card bg-white">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-success bg-opacity-10 p-2 rounded me-2">
                                <i class="fas fa-check-circle text-success"></i>
                            </div>
                            <div>
                                <small class="text-muted">Active Contracts</small>
                                <h5 class="mb-0">@(Model.Contracts?.Count(c => c.Status == ContractStatus.Active) ?? 0)</h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-history me-2 text-primary"></i>Contracts History</h5>
                <a asp-controller="Contracts" asp-action="Create" asp-route-clientId="@Model.ClientId" class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-plus me-1"></i> Add
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model.Contracts == null || !Model.Contracts.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-file-signature fa-3x mb-3 text-muted opacity-50"></i>
                        <p>No contracts yet.</p>
                        <a asp-controller="Contracts" asp-action="Create" asp-route-clientId="@Model.ClientId" class="btn btn-primary">
                            Create First Contract
                        </a>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var contract in Model.Contracts.OrderByDescending(c => c.StartDate))
                        {
                            string contractBadge = contract.Status switch
                            {
                                ContractStatus.Active => "badge-active",
                                ContractStatus.Expired => "badge-expired",
                                ContractStatus.Draft => "badge-draft",
                                ContractStatus.OnHold => "badge-onhold",
                                _ => ""
                            };
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <a asp-controller="Contracts" asp-action="Details" asp-route-id="@contract.ContractId" class="fw-semibold">
                                            Contract #@contract.ContractId
                                        </a>
                                        <div class="small text-muted">
                                            @contract.StartDate.ToString("dd MMM yyyy") - @contract.EndDate.ToString("dd MMM yyyy")
                                        </div>
                                    </div>
                                    <div>
                                        <span class="badge-status @contractBadge">@contract.Status</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Delete Danger Zone (optional) -->
<div class="card border-danger mt-4">
    <div class="card-header bg-danger bg-opacity-10 text-danger border-danger">
        <i class="fas fa-exclamation-triangle me-2"></i>Danger Zone
    </div>
    <div class="card-body">
        <p class="mb-3">Deleting this client will permanently remove all associated data. This action cannot be undone.</p>
        <form asp-action="Delete" asp-route-id="@Model.ClientId" method="post" onsubmit="return confirm('Are you absolutely sure? This cannot be undone.');">
            <button type="submit" class="btn btn-outline-danger" @(Model.Contracts?.Any() == true ? "disabled" : "")>
                <i class="fas fa-trash-alt me-1"></i> Delete Client
            </button>
            @if (Model.Contracts?.Any() == true)
            {
                <small class="text-muted ms-2">Cannot delete client with existing contracts.</small>
            }
        </form>
    </div>
</div>